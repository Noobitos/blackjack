generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// role: "USER" | "ADMIN"
model User {
  id           String        @id @default(cuid())
  username     String        @unique
  password     String
  role         String        @default("USER")
  pocket       Decimal       @default(0)
  bank         Decimal       @default(0)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  gameSessions GameSession[]
}

// type: "CASH_GENERATION" | "ADMIN_SEND" | "TABLE_FUND" | "BANK_DEPOSIT" | "BANK_WITHDRAW" | "BET_PLACED" | "BET_WIN" | "BET_PUSH"
model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  amount    Decimal
  note      String?
  createdAt DateTime @default(now())
}

model Table {
  id       Int           @id
  name     String
  minBet   Decimal
  maxBet   Decimal
  balance  Decimal       @default(50000000)
  isOpen   Boolean       @default(true)
  sessions GameSession[]
}

// status: "IN_PROGRESS" | "COMPLETED"
// outcome: "WIN" | "LOSS" | "PUSH" | "BLACKJACK" | null
model GameSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  tableId    Int
  table      Table    @relation(fields: [tableId], references: [id])
  betAmount  Decimal
  playerHand String
  dealerHand String
  deck       String
  status     String   @default("IN_PROGRESS")
  outcome    String?
  createdAt  DateTime @default(now())
}
